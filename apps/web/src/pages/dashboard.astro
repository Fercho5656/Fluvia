---
import Layout from "../layouts/Layout.astro";
import { createClient } from "../lib/orpc";

// Only authenticated users can access this
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}

const client = createClient(Astro.request.headers);
let apiMessage = "Failed to load server data";
try {
  const data = await client.privateData();
  apiMessage = data.message;
} catch (e) {
  console.error("Failed to fetch private data:", e);
}
---

<Layout title="Dashboard - Fluvia">
  <main class="mx-auto max-w-4xl px-4 py-8">
    <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-8">
      <h1 class="text-3xl font-bold text-white mb-6">Dashboard</h1>
      
      <div class="space-y-4">
        <div class="rounded-lg bg-neutral-800/50 p-4">
          <p class="text-sm text-neutral-400">Welcome back,</p>
          <p class="text-xl font-medium text-white">{user.name || "User"}</p>
        </div>
        
        <div class="rounded-lg bg-neutral-800/50 p-4">
          <p class="text-sm text-neutral-400 mb-2">Email</p>
          <p class="text-white">{user.email}</p>
        </div>

        <div class="rounded-lg bg-neutral-800/50 p-4">
          <p class="text-sm text-neutral-400 mb-2">Server Message</p>
          <p class="text-white">{apiMessage}</p>
        </div>
      </div>

      <div class="mt-8 flex gap-4">
        <a href="/fluvia" class="bg-primary hover:bg-primary/90 text-white px-6 py-2.5 rounded-lg font-medium transition-colors">
          Go to Agency Command
        </a>
      </div>
    </div>
  </main>
</Layout>
