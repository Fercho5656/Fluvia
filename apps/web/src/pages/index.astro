---
import Layout from "../layouts/Layout.astro";

const TITLE_TEXT = `
 ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó 
 ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
 ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
 ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ
 ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
 ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ   ‚ēö‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ
 
    AI-POWERED AUTOMATION INFRASTRUCTURE
 `;
---

<Layout title="Fluvia - AI Automation Infrastructure">
  <div class="container mx-auto max-w-4xl px-4 py-12 md:py-24">
    <div class="flex flex-col items-center text-center space-y-8">
      <pre class="overflow-x-auto font-mono text-[10px] md:text-sm text-primary leading-tight">{TITLE_TEXT}</pre>
      
      <div class="space-y-4 max-w-2xl">
        <h1 class="text-5xl md:text-6xl font-black tracking-tighter text-white">
          Deploy automation <span class="text-primary">at scale.</span>
        </h1>
        <p class="text-xl text-muted-foreground">
          The infrastructure layer for agencies. Provision CubePath servers, generate n8n workflows with AI, and manage client automations from a single command center.
        </p>
      </div>

      <div class="flex gap-4 pt-4">
        <a href="/fluvia" class="bg-primary hover:bg-primary/90 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-2xl shadow-primary/20">
          Open Agency Command
        </a>
        <a href="/login" class="bg-surface-elevated hover:bg-surface-highest border border-border text-white px-8 py-4 rounded-xl font-bold text-lg transition-all">
          Sign In
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full pt-12">
        <div class="glass-panel p-6 rounded-2xl text-left space-y-3">
          <div class="size-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          </div>
          <h3 class="font-bold text-white">CubePath Provisioning</h3>
          <p class="text-sm text-muted-foreground">One-click deployment of dedicated automation servers for every client workspace.</p>
        </div>
        <div class="glass-panel p-6 rounded-2xl text-left space-y-3">
           <div class="size-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="font-bold text-white">AI Workflow Agent</h3>
          <p class="text-sm text-muted-foreground">Describe your business logic in plain English. We'll generate the n8n JSON automatically.</p>
        </div>
        <div class="glass-panel p-6 rounded-2xl text-left space-y-3">
           <div class="size-10 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.040L3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622l-.982-3.016z" /></svg>
          </div>
          <h3 class="font-bold text-white">Agency Multi-tenancy</h3>
          <p class="text-sm text-muted-foreground">Securely manage multiple client environments from a single unified interface.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
