---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import Card from "@/components/ui/Card.astro";
import LandingAiShowcase from "@/components/fluvia/LandingAiShowcase.vue";

const user = Astro.locals.user;

if (user) {
  return Astro.redirect("/dashboard");
}
---

<Layout title="Fluvia | Instant n8n Infrastructure for Agencies">
  <main
    class="bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-size-[14px_24px]"
  >
    <!-- Hero Section -->
    <section
      id="hero-section"
      class="relative min-h-[90vh] flex flex-col items-center justify-start overflow-hidden px-8 pt-54"
    >
      <div
        class="absolute inset-0 bg-lineal-to-b from-primary-container/10 to-transparent pointer-events-none"
      >
      </div>
      <div
        class="max-w-4xl mx-auto text-center z-20 relative mb-16 hero-content"
      >
        <Badge variant="primary" class="mb-6 opacity-0">
          The Instant n8n Infrastructure
        </Badge>
        <h1
          class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-8 leading-[1.1] opacity-0"
        >
          Deploy automation <br />
          <span class="text-primary-container">at scale</span>
        </h1>
        <p
          class="font-body text-lg md:text-xl text-on-surface-variant max-w-2xl mx-auto mb-12 leading-relaxed opacity-0"
        >
          Launch dedicated n8n instances for every client with a single click.
          No DevOps experience required. Build complex logic using natural
          language with our built-in AI Architect.
        </p>
        <div
          class="flex flex-col md:flex-row items-center justify-center gap-6 opacity-0 hero-actions"
        >
          <Button href="/signup" size="lg" class="w-full md:w-auto">
            Launch Instance
          </Button>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features-section" class="py-24 px-8 bg-surface">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-2xl mb-16 feature-header opacity-0">
          <h2
            class="font-headline text-4xl font-bold tracking-tight text-on-surface mb-6"
          >
            Engineered for ease, built for scale.
          </h2>
          <p class="text-on-surface-variant text-lg">
            We've removed the technical hurdles of self-hosting n8n, giving you
            the power to manage dozens of clients without the server headaches.
          </p>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-[400px]"
        >
          <!-- AI Workflow Architect (Primary Bento Piece - Full Width) -->
          <Card
            variant="low"
            class="p-1 feature-card opacity-0 md:col-span-2 lg:col-span-3 lg:row-span-2 !h-full"
          >
            <div
              class="bg-surface-container-low rounded-lg p-10 h-full flex flex-col lg:flex-row gap-12 group"
            >
              <div class="lg:w-1/3 space-y-6">
                <div
                  class="w-14 h-14 bg-primary-container/10 rounded-lg flex items-center justify-center mb-2 border border-primary-container/20"
                >
                  <span
                    class="material-symbols-outlined text-primary-container text-3xl"
                    >psychology</span
                  >
                </div>
                <h3
                  class="font-headline text-4xl font-bold text-on-surface tracking-tight"
                >
                  AI Workflow Architect
                </h3>
                <p
                  class="font-body text-on-surface-variant text-lg leading-relaxed"
                >
                  The heart of Fluvia. Translate complex business logic into
                  production-ready n8n blueprints via natural language.
                  <br /><br />
                  Iteratively refine your designs with our interactive architect chat
                  and visualize the outcome in real-time.
                </p>
                <div class="flex items-center gap-2 pt-4">
                  <div class="flex -space-x-2">
                    <div
                      class="size-8 rounded-full border-2 border-surface bg-primary/20 flex items-center justify-center text-[10px] font-bold text-primary"
                    >
                      n8n
                    </div>
                    <div
                      class="size-8 rounded-full border-2 border-surface bg-blue-500/20 flex items-center justify-center text-[10px] font-bold text-blue-400"
                    >
                      AI
                    </div>
                  </div>
                  <span
                    class="text-xs font-bold text-on-surface/40 uppercase tracking-widest ml-2"
                    >Enterprise Ready</span
                  >
                </div>
              </div>

              <div
                class="flex-1 bg-surface-container-lowest rounded-2xl border border-outline-variant/10 p-6 font-mono text-sm relative overflow-hidden flex flex-col shadow-inner"
              >
                <div class="flex items-center justify-between mb-4 px-2">
                  <div class="flex items-center gap-2 text-primary-container">
                    <span
                      class="w-2 h-2 rounded-full bg-primary-container animate-pulse"
                    ></span>
                    <span
                      class="text-[10px] font-bold tracking-widest uppercase"
                      >architect_engine_live</span
                    >
                  </div>
                  <span
                    class="text-[9px] text-on-surface/20 font-bold uppercase tracking-tighter"
                    >v2.4.0-stable</span
                  >
                </div>
                <LandingAiShowcase client:visible />
              </div>
            </div>
          </Card>

          <!-- CubePath Provisioning (Secondary Bento Piece) -->
          <Card
            variant="low"
            class="p-1 feature-card opacity-0 md:col-span-2 lg:col-span-2 !h-full"
          >
            <div
              class="bg-surface-container-low rounded-lg p-10 h-full flex flex-col md:flex-row gap-10 group overflow-hidden"
            >
              <div class="md:w-1/2">
                <div
                  class="w-12 h-12 bg-primary-container/10 rounded-lg flex items-center justify-center mb-6 border border-primary-container/20"
                >
                  <span
                    class="material-symbols-outlined text-primary-container text-2xl"
                    >view_in_ar</span
                  >
                </div>
                <h3
                  class="font-headline text-2xl font-bold text-on-surface mb-4"
                >
                  CubePath Provisioning
                </h3>
                <p
                  class="font-body text-on-surface-variant text-base leading-relaxed"
                >
                  Zero-DevOps infrastructure. Deploy dedicated VPS nodes for
                  every client with one click.
                </p>
              </div>
              <div
                class="md:w-1/2 relative rounded-xl overflow-hidden border border-outline-variant/10 shadow-xl mt-auto md:mt-0"
              >
                <img
                  class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
                  alt="digital node visualization"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuAAQ8q9g6nz2DFfT40HmpMtdYBiy6Z4R-eQATk4UhDDMHgjdYJ1LTjJ2JQkOIp92-roMCbcbh76AcSWarue4njHh4bYz7dz21ODpFIgbhfocbWp5iSjJetJzp-lqAn8FP4iYgPEQkvM15qIc5WEyQZqbx5Yzwh9NDTzIMGJboOkbaY3XCeKw4iiWNqpde5woLrHZ1wUkFdBVeymyBIy_oU1JqFzD6n7SHkIgk0jXYFu3x7OUB5te28he73cQc-0K-jgrw-JrZbvxNP7"
                />
              </div>
            </div>
          </Card>

          <!-- Agency-First Orchestration (Tertiary Bento Piece) -->
          <Card
            variant="low"
            class="p-1 feature-card opacity-0 lg:col-span-1 !h-full"
          >
            <div
              class="bg-primary-container/5 rounded-lg p-10 h-full flex flex-col border border-primary-container/10 relative overflow-hidden group"
            >
              <div class="relative z-10">
                <div
                  class="w-12 h-12 bg-primary-container/20 rounded-lg flex items-center justify-center mb-6 border border-primary-container/30"
                >
                  <span
                    class="material-symbols-outlined text-primary-container text-2xl"
                    >hub</span
                  >
                </div>
                <h3
                  class="font-headline text-2xl font-bold text-on-surface mb-4 text-white"
                >
                  Agency Core
                </h3>
                <p
                  class="font-body text-on-surface-variant text-sm leading-relaxed mb-6"
                >
                  Manage multiple clients from a single unified command center.
                  Perfect for automation agencies scaling their operations.
                </p>
                <div class="space-y-3">
                  <div
                    class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden"
                  >
                    <div class="h-full bg-primary w-3/4"></div>
                  </div>
                  <div
                    class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden"
                  >
                    <div class="h-full bg-primary w-1/2"></div>
                  </div>
                </div>
              </div>
              <!-- Abstract visual background -->
              <div
                class="absolute -bottom-10 -right-10 size-40 bg-primary/10 blur-3xl rounded-full group-hover:scale-150 transition-transform duration-1000"
              >
              </div>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-32 px-8">
      <Card
        variant="low"
        id="cta-section"
        class="max-w-5xl mx-auto p-12 md:p-20 text-center relative opacity-0"
      >
        <div
          class="absolute inset-0 bg-lineal-to-tr from-primary-container/10 via-transparent to-transparent"
        >
        </div>
        <h2
          class="font-headline text-4xl md:text-5xl font-extrabold text-on-surface mb-8 relative z-10"
        >
          Start deploying today.
        </h2>
        <p class="text-on-surface-variant mb-12 relative z-10 max-w-xl mx-auto">
          No credit card required to explore the dashboard. Deploy your first
          client instance in under 60 seconds.
        </p>
        <div
          class="flex flex-col md:flex-row items-center justify-center gap-4 relative z-10"
        >
          <Button href="/signup" size="lg">Get Started Free</Button>
        </div>
      </Card>
    </section>
  </main>

  <!-- Footer -->
  <footer
    class="bg-surface-container-lowest w-full py-12 px-8 border-t border-surface-container-low"
  >
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-7xl mx-auto mb-12">
      <div>
        <div class="text-xl font-bold text-on-surface font-headline mb-6">
          Fluvia
        </div>
        <p
          class="font-body text-sm text-on-surface-variant max-w-xs leading-relaxed"
        >
          The agency-first infrastructure layer for seamless n8n deployment and
          AI-driven automation.
        </p>
      </div>
    </div>
    <div
      class="max-w-7xl mx-auto pt-12 border-t border-surface-container-low flex flex-col md:flex-row justify-between items-center gap-6"
    >
      <p class="font-body text-sm text-on-surface-variant">
        Midudev & CubePath - 2026 Hackathon
      </p>
      <div class="flex gap-6">
        <a
          class="text-on-surface-variant hover:text-on-surface transition-colors"
          href="https://github.com/Fercho5656/Fluvia"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="material-symbols-outlined">code</span>
        </a>
      </div>
    </div>
  </footer>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Initial Hero Animation
    const tl = gsap.timeline();
    tl.to(".hero-content > *", {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.1,
      ease: "power2.out",
      startAt: { y: 20 },
    }).to(
      ".hero-image",
      {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power2.out",
        startAt: { y: 40 },
      },
      "-=0.6",
    );

    // Features Section Entrance
    gsap.to(".feature-header", {
      scrollTrigger: {
        trigger: "#features-section",
        start: "top 80%",
      },
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: "power2.out",
      startAt: { y: 30 },
    });

    gsap.to(".feature-card", {
      scrollTrigger: {
        trigger: ".feature-card",
        start: "top 85%",
      },
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: "power2.out",
      startAt: { y: 40 },
    });

    // CTA Section Subtle Reveal
    gsap.to("#cta-section", {
      scrollTrigger: {
        trigger: "#cta-section",
        start: "top 90%",
      },
      opacity: 1,
      scale: 1,
      duration: 1,
      ease: "power2.out",
      startAt: { scale: 0.95 },
    });
  </script>
</Layout>
