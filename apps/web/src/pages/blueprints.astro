---
import Layout from "@/layouts/Layout.astro";
import WorkflowLibrary from "@/components/fluvia/WorkflowLibrary.vue";

// Auth guard
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}
---

<Layout title="My Blueprints - Fluvia">
  <main class="mx-auto max-w-7xl px-4 py-12 md:px-8">
    <WorkflowLibrary client:load />
  </main>
</Layout>
