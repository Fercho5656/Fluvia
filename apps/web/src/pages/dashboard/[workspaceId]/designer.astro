---
import Layout from "../../../layouts/Layout.astro";
import WorkflowDesigner from "../../../components/fluvia/WorkflowDesigner.vue";

const { workspaceId } = Astro.params;
const serverId = Astro.url.searchParams.get("serverId");

if (!workspaceId || !serverId) {
  return Astro.redirect("/fluvia");
}

// Only authenticated users can access this
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}
---

<Layout title="Fluvia Designer">
  <main class="mx-auto max-w-7xl px-4 py-12 md:px-8">
    <WorkflowDesigner 
      workspaceId={workspaceId} 
      serverId={serverId} 
      client:load 
    />
  </main>
</Layout>
