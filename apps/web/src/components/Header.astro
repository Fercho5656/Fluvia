---
import Button from "@/components/ui/Button.astro";

interface Props {
  user?: import("better-auth").User | null;
}

const { user } = Astro.props;

const links = [
  { to: "/dashboard", label: "Dashboard" },
  { to: "/dashboard/designer", label: "AI Designer" },
  { to: "/dashboard/workflows", label: "My Blueprints" },
];
---

<div
  class="sticky top-0 z-50 bg-surface/80 backdrop-blur-xl border-b border-outline-variant/10 shadow-2xl shadow-primary-container/5"
>
  <div
    class="mx-auto max-w-7xl flex flex-row items-center justify-between px-4 py-4 md:px-8"
  >
    <nav class="flex gap-8 items-center">
      <a
        href="/"
        class="text-2xl font-bold tracking-tighter text-on-surface font-headline"
        >Fluvia</a
      >
      <div class="hidden md:flex gap-8">
        {
          user
            ? links.map((link) => (
                <a
                  href={link.to}
                  class="text-sm font-bold font-headline tracking-tight text-on-surface/70 hover:text-on-surface transition-colors"
                >
                  {link.label}
                </a>
              ))
            : null
        }
      </div>
    </nav>

    <div class="flex items-center gap-4">
      {
        user ? (
          <div class="flex items-center gap-4">
            <div class="flex flex-col items-end sm:flex">
              <span class="text-sm font-bold text-on-surface leading-none">
                {user.name}
              </span>
              <span class="text-[10px] text-on-surface-variant font-mono uppercase tracking-widest">
                {user.email.split("@")[0]}
              </span>
            </div>
            <Button
              id="signout-button"
              variant="secondary"
              size="sm"
              class="bg-error-container/10 hover:bg-error-container/20 text-error border-error-container/20"
            >
              Sign Out
            </Button>
          </div>
        ) : (
          <div class="flex items-center gap-4">
            <a
              href="/login"
              class="text-sm font-bold font-headline tracking-tight text-on-surface/70 hover:text-on-surface px-2"
            >
              Sign In
            </a>
            <Button href="/signup" size="sm">
              Get Started
            </Button>
          </div>
        )
      }
    </div>
  </div>
</div>

<script>
  import { authClient } from "@/lib/auth-client";

  const signOutButton = document.getElementById("signout-button");

  signOutButton?.addEventListener("click", async () => {
    await authClient.signOut({
      fetchOptions: {
        onSuccess: () => {
          window.location.href = "/";
        },
      },
    });
  });
</script>
