---
interface Props {
  user?: import("better-auth").User | null;
}

const { user } = Astro.props;

const links = [{ to: "/dashboard", label: "Dashboard" }];
---

<div class="sticky top-0 z-50 glass-panel border-x-0 border-t-0">
  <div
    class="mx-auto max-w-7xl flex flex-row items-center justify-between px-4 py-3 md:px-8"
  >
    <nav class="flex gap-6 items-center">
      <a href="/" class="text-xl font-black tracking-tighter text-white mr-4"
        >FLUVIA</a
      >
      <div class="hidden md:flex gap-6">
        {
          links.map((link) => (
            <a
              href={link.to}
              class="text-sm font-medium text-muted-foreground hover:text-white transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </nav>

    <div class="flex items-center gap-4">
      {
        user ? (
          <div class="flex items-center gap-4">
            <div class="flex flex-col items-end sm:flex">
              <span class="text-sm font-bold text-white leading-none">
                {user.name}
              </span>
              <span class="text-[10px] text-muted-foreground font-mono">
                {user.email.split("@")[0]}
              </span>
            </div>
            <button
              id="signout-button"
              class="rounded-lg px-4 py-2 text-sm font-bold bg-rose-500/10 hover:bg-rose-500/20 text-rose-500 border border-rose-500/20 transition-all"
            >
              Sign Out
            </button>
          </div>
        ) : (
          <div class="flex items-center gap-2">
            <a
              href="/login"
              class="text-sm font-medium text-muted-foreground hover:text-white px-4 py-2"
            >
              Sign In
            </a>
            <a
              href="/signup"
              class="rounded-lg px-4 py-2 text-sm font-bold bg-primary hover:bg-primary/90 text-white shadow-lg shadow-primary/20 transition-all"
            >
              Get Started
            </a>
          </div>
        )
      }
    </div>
  </div>
</div>

<script>
  import { authClient } from "@/lib/auth-client";

  const signOutButton = document.getElementById("signout-button");

  signOutButton?.addEventListener("click", async () => {
    await authClient.signOut({
      fetchOptions: {
        onSuccess: () => {
          window.location.href = "/";
        },
      },
    });
  });
</script>
