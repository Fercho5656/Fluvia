---
import { cn } from "@/lib/utils";

interface Props {
  variant?: "primary" | "secondary" | "outline";
  class?: string;
}

const { variant = "primary", class: className } = Astro.props;

const variants = {
  primary: "bg-surface-container-highest text-primary border-outline-variant/20",
  secondary: "bg-secondary-container text-on-secondary-container border-outline-variant/10",
  outline: "bg-transparent text-on-surface-variant border-outline-variant/30",
};

const baseStyles =
  "inline-flex items-center px-3 py-1 rounded-full text-[10px] font-label uppercase tracking-widest border";
---

<span class={cn(baseStyles, variants[variant], className)}>
  <slot />
</span>
