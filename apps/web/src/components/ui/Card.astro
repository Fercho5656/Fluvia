---
import { cn } from "@/lib/utils";

interface Props {
  variant?: "default" | "low" | "lowest" | "gradient";
  class?: string;
  [key: string]: any;
}

const { variant = "default", class: className, ...props } = Astro.props;

const baseStyles = "rounded-xl overflow-hidden border border-outline-variant/10 transition-all";

const variants = {
  default: "bg-surface-container",
  low: "bg-surface-container-low",
  lowest: "bg-surface-container-lowest",
  gradient: "bg-surface-container-low bg-gradient-to-b from-primary-container/10 to-transparent",
};
---

<div class={cn(baseStyles, variants[variant], className)} {...props}>
  <slot />
</div>
